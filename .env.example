# Copy to .env and set strong secrets before `docker compose up`.

SPSYNCAPI_AUTH_JWT_SECRET=change-me-jwt-secret-min-32-chars
SPSYNCAPI_ENCRYPTION_SECRET=change-me-encryption-secret-min-32-chars

# Production compose only (docker-compose.prod.yml)
SPSYNCAPI_DB_DRIVER=postgres
SPSYNCAPI_DB_POSTGRES_DSN=host=app-postgresql port=5432 user=spsync password=spsync dbname=spsyncapi sslmode=disable

# UI → API (BFF proxy target inside Docker network)
SPSYNC_API_URL=http://spsyncapi:8080
